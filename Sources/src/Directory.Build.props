<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup Condition="'$(MSBuildProjectExtension)'=='.vcxproj'">
	<VCProjectVersion Condition="'$(VCProjectVersion)'==''">$(VisualStudioVersion)</VCProjectVersion>
	<PlatformToolset Condition="'$(PlatformToolset)'=='' and '$(DefaultPlatformToolset)'!=''">$(DefaultPlatformToolset)</PlatformToolset>
  </PropertyGroup>
  <ItemDefinitionGroup Condition="'$(MSBuildProjectExtension)'=='.vcxproj'">
	<ClCompile>
	  <PreprocessorDefinitions>_WINSOCK_DEPRECATED_NO_WARNINGS;%(PreprocessorDefinitions)</PreprocessorDefinitions>
	  <DisableSpecificWarnings>4996;%(DisableSpecificWarnings)</DisableSpecificWarnings>
	</ClCompile>
  </ItemDefinitionGroup>
</Project>
